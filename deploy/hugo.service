# HUGO systemd user service (VEN-56 ops). Install with
# scripts/install_systemd_service.sh, then:
#
#   systemctl --user start hugo      # load models, start the voice loop
#   systemctl --user stop hugo       # graceful sleep: rest posture + full teardown
#   journalctl --user -u hugo -f     # live logs, persistent across restarts
#
# One-time on a fresh machine: `loginctl enable-linger` so the service
# survives SSH logout. Deliberately NO Restart= — a crashed HUGO must
# release the shared box's memory, not fight to reclaim it (ADR 0002).

[Unit]
Description=HUGO voice assistant (model servers + voice loop)

[Service]
Type=simple
WorkingDirectory=%h/hugo
# Plain KEY=VALUE lines (no `export` — systemd doesn't parse it):
# HUGO_TAVILY_API_KEY, HUGO_PLAYBACK_GAIN, and any other HUGO_* overrides.
EnvironmentFile=%h/.hugo_secrets
# The reachy_mini SDK auto-spawns `reachy-mini-daemon` via PATH lookup
# when no daemon answers. Under systemd the venv bin is not on PATH, so
# a dead daemon meant FileNotFoundError + a crash-looping service
# (live 2026-07-24, the first time the daemon ever died under systemd).
Environment=PATH=%h/hugo/.venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/hugo/.venv/bin/hugo start
# SIGTERM is hugo's graceful sleep path (CONTEXT.md: Sleep). Model
# teardown takes tens of seconds; give it room before systemd escalates.
KillSignal=SIGTERM
TimeoutStopSec=180
Restart=no
# Shutdown ends with hugo's own group-wide SIGKILL sweep (the orphaned-
# EngineCore safety net), which takes hugo itself with it by design —
# that's a successful stop, not a crash.
SuccessExitStatus=SIGKILL

[Install]
WantedBy=default.target
